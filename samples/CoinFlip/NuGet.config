<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="botframework-local" value="../../.artifacts/local-feed" />
    <!-- Only BotFramework direct references are pinned to the local feed;
         ordinary transitive dependencies remain ordinary NuGet packages. -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
