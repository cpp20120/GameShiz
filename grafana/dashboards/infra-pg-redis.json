        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "11.2.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "(time() - max(pg_postmaster_start_time_seconds)) or (time() - max(container_start_time_seconds{job=\"cadvisor\",container_label_com_docker_compose_service=\"postgres\"})) or (time() - max(container_start_time_seconds{job=\"cadvisor\",name=~\".*postgres.*\",name!~\".*exporter.*\"})) or (time() - max(process_start_time_seconds{job=\"postgres\"}))",
          "format": "time_series",
          "instant": true,
          "legendFormat": "postgres uptime",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "PostgreSQL \u2014 uptime",
      "type": "stat"
