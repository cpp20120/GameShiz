      "description": "PostgreSQL uptime. Uses postgres-exporter postmaster start time when available, then cAdvisor container start time, then postgres-exporter process uptime as a last fallback.",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
