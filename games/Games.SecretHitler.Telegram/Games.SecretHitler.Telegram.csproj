<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Telegram.Bot" Version="22.10.1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\framework\BotFramework.Host\BotFramework.Host.csproj" />
    <ProjectReference Include="..\Games.SecretHitler.Contracts\Games.SecretHitler.Contracts.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="GlobalUsings.cs" />
    <Compile Include="SecretHitlerTelegramModule.cs" />
    <Compile Include="..\Games.SecretHitler\Application\Handlers\SecretHitlerHandler.cs" Link="SecretHitlerHandler.cs" />
    <Compile Include="..\Games.SecretHitler\Infrastructure\Rendering\**\*.cs" Link="Rendering\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>
</Project>
