<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>



    <RootNamespace>Games.Poker</RootNamespace>
    <AllowMissingPrunePackageData>true</AllowMissingPrunePackageData>
    <NuGetAuditMode>direct</NuGetAuditMode>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Dapper" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Update="Meziantou.Analyzer" PrivateAssets="all" IncludeAssets="runtime; build; native; contentfiles; analyzers" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\framework\BotFramework.Host\BotFramework.Host.csproj" />
    <ProjectReference Include="..\Games.Poker.Contracts\Games.Poker.Contracts.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="Domain\**\*.cs" />
    <Compile Remove="Application\Services\IPokerService.cs" />
    <Compile Remove="Application\Handlers\**\*.cs" />
    <Compile Remove="Application\Jobs\**\*.cs" />
    <Compile Remove="Infrastructure\Rendering\**\*.cs" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>
</Project>
