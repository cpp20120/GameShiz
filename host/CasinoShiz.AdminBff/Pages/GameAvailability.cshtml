@page "/admin/game-availability"
@model GameAvailabilityModel
@{ ViewData["Title"] = "Game availability"; }
<div class="page-heading"><div><div class="eyebrow">Runtime controls</div><h1>Game availability</h1><p class="lede">Chat overrides take precedence over global game configuration. Changes are operator actions and stay scoped to one chat.</p></div><a class="button secondary" href="/admin/game-availability">Refresh</a></div>
@if (TempData["flash"] is string flash) { <div class="flash">@flash</div> } @if (TempData["error-message"] is string message) { <div class="flash error">@message</div> } @if (Model.Error is not null) { <div class="flash error">@Model.Error</div> }
<div class="card toolbar-card"><form method="get" class="toolbar"><label>Chat ID<input asp-for="ChatId" placeholder="all chats" /></label><button type="submit">Load overrides</button></form></div>
@if (Model.CanMutate) {
<div class="card"><div class="card-heading"><div><h2>Set override</h2><p class="muted">Use a reason that will be useful in the audit trail.</p></div><span class="pill ok">SuperAdmin</span></div><form method="post" class="form-grid"><label>Chat ID<input asp-for="ChatId" required /></label><label>Game ID<input asp-for="GameId" required placeholder="blackjack" /></label><label>Reason<input asp-for="Reason" required maxlength="500" placeholder="maintenance" /></label><label><span>State</span><select asp-for="Enabled"><option value="true">Enabled</option><option value="false">Disabled</option></select></label><button type="submit">Save override</button></form></div>
}
<div class="card table-card"><div class="card-heading"><div><h2>Current overrides</h2><p class="muted">@Model.Overrides.Count rows returned.</p></div></div><div class="table-wrap"><table><thead><tr><th>Chat</th><th>Game</th><th>State</th><th>Reason</th><th>Actor</th><th>Changed</th></tr></thead><tbody>@foreach (var item in Model.Overrides) { <tr><td><code>@item.ChatId</code></td><td><code>@item.GameId</code></td><td><span class="pill @(item.Enabled ? "ok" : "warn")">@(item.Enabled ? "enabled" : "disabled")</span></td><td>@item.Reason</td><td>@item.ChangedBy</td><td class="muted">@item.ChangedAt</td></tr> } @if (Model.Overrides.Count == 0) { <tr><td colspan="6" class="empty">No chat overrides match the filter.</td></tr> }</tbody></table></div></div>
