@page "/admin/audit"
@model AuditModel
@{ ViewData["Title"] = "Audit"; }
<div class="page-heading"><div><div class="eyebrow">Operations service</div><h1>Audit trail</h1><p class="lede">Immutable operator actions with filters and export. Use this page to answer who changed what and when.</p></div><div class="inline"><a class="button secondary" asp-page-handler="Csv" asp-route-actor="@Model.Actor" asp-route-action="@Model.Action" asp-route-details="@Model.Details" asp-route-from="@Model.From" asp-route-until="@Model.Until">Export CSV</a><a class="button secondary" asp-page-handler="Json" asp-route-actor="@Model.Actor" asp-route-action="@Model.Action" asp-route-details="@Model.Details" asp-route-from="@Model.From" asp-route-until="@Model.Until">Export JSON</a></div></div>
<div class="card toolbar-card"><form method="get" class="form-grid"><label>Actor<input asp-for="Actor" placeholder="name or id" /></label><label>Action<input asp-for="Action" placeholder="recovery.retry" /></label><label>Details<input asp-for="Details" placeholder="text in JSON" /></label><label>From<input asp-for="From" type="datetime-local" /></label><label>Until<input asp-for="Until" type="datetime-local" /></label><button type="submit">Apply filters</button></form></div>
@if (Model.Error is not null) { <div class="flash error">@Model.Error</div> }
<div class="card table-card"><div class="card-heading"><div><h2>Recent actions</h2><p class="muted">@Model.Rows.Count records shown.</p></div><span class="pill">read only</span></div><div class="table-wrap"><table><thead><tr><th>Time</th><th>Actor</th><th>Action</th><th>Details</th></tr></thead><tbody>@foreach (var x in Model.Rows) { <tr><td class="muted">@x.OccurredAt.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</td><td><strong>@x.ActorName</strong><br /><code>@x.ActorId</code></td><td><span class="pill">@x.Action</span></td><td><pre>@x.DetailsJson</pre></td></tr> } @if (Model.Rows.Count == 0) { <tr><td colspan="4" class="empty">No audit actions match the filters.</td></tr> }</tbody></table></div></div>
