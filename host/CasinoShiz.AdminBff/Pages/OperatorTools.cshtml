@page "/admin/operator-tools"
@model OperatorToolsModel
@{ ViewData["Title"] = "Operator tools"; }
<div class="page-heading"><div><div class="eyebrow">SuperAdmin utilities</div><h1>Operator tools</h1><p class="lede">Safe, explicit diagnostics for replay and economy scenarios. Nothing here silently changes production state.</p></div><span class="pill @(Model.CanUse ? "ok" : "warn")">@(Model.CanUse ? "SuperAdmin" : "read only")</span></div>
@if (!Model.CanUse) { <div class="flash error">Replay and simulation require SuperAdmin.</div> } else {
<div class="split-grid"><div class="card"><div class="card-heading"><div><h2>Event replay</h2><p class="muted">Read-only replay of a persisted stream.</p></div></div><form method="post" asp-page-handler="Replay" class="toolbar"><label>Stream ID<input asp-for="StreamId" required placeholder="stream id" /></label><button type="submit">Replay</button></form>@if (Model.Replay is not null) { <div class="flash">@Model.Replay.Steps.Count events · first incompatible: @(Model.Replay.FirstIncompatibleVersion?.ToString() ?? "none")</div> }</div>
<div class="card"><div class="card-heading"><div><h2>Economy simulation</h2><p class="muted">Deterministic scenario, recorded as an operator action.</p></div></div><form method="post" asp-page-handler="Simulate" class="form-grid"><label>Players<input asp-for="Players" /></label><label>Rounds<input asp-for="Rounds" /></label><label>Seed<input asp-for="Seed" /></label><label>Starting balance<input asp-for="StartingBalance" /></label><label>Stake<input asp-for="Stake" /></label><label>Win payout<input asp-for="WinPayout" /></label><label>Win probability<input asp-for="WinProbability" /></label><button type="submit">Simulate</button></form>@if (Model.Simulation is not null) { <div class="key-values"><span>Emission <b>@Model.Simulation.Emission</b></span><span>Sinks <b>@Model.Simulation.Sinks</b></span><span>RTP <b>@Model.Simulation.Rtp</b></span></div> }</div></div>
}
<div class="card table-card"><div class="card-heading"><div><h2>Incomplete fairness commitments</h2><p class="muted">Streams still waiting for a completion proof.</p></div><span class="pill @(Model.Incomplete.Count == 0 ? "ok" : "warn")">@Model.Incomplete.Count</span></div><div class="table-wrap"><table><thead><tr><th>ID</th><th>Game</th><th>Algorithm</th><th>Created</th></tr></thead><tbody>@foreach (var item in Model.Incomplete) { <tr><td><code>@item.Id</code></td><td>@item.GameId</td><td>@item.AlgorithmVersion</td><td class="muted">@item.CreatedAt</td></tr> } @if (Model.Incomplete.Count == 0) { <tr><td colspan="4" class="empty">No incomplete commitments.</td></tr> }</tbody></table></div></div>
