@page "/admin/people"
@model IdentityModel
@{ ViewData["Title"] = "Identity"; }
<h1>Identity</h1><form method="get"><input asp-for="Query" placeholder="Telegram ID or @@username"/><button>Find</button></form>
@if(Model.Error is not null){<p class="error">@Model.Error</p>}
@if(Model.Identity is not null){<div class="card"><dl><dt>User ID</dt><dd>@Model.Identity.UserId</dd><dt>Name</dt><dd>@Model.Identity.DisplayName</dd><dt>Username</dt><dd>@Model.Identity.Username</dd><dt>Last seen</dt><dd>@Model.Identity.LastSeenAt</dd></dl></div>}
