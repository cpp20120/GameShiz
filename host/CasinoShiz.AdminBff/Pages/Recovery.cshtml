@page "/admin/recovery"
@model RecoveryModel
@{ ViewData["Title"] = "Recovery"; }

<div class="page-heading"><div><div class="eyebrow">Operations service</div><h1>Recovery</h1><p class="lede">Retry persisted event failures and release stuck outbox records. Every mutation is sent through the operations service and keeps its audit trail.</p></div><a class="button secondary" href="/admin/recovery">Refresh</a></div>
@if (TempData["flash"] is string flash) { <div class="flash">@flash</div> } @if (TempData["error-message"] is string error) { <div class="flash error">@error</div> } @if (Model.Error is not null) { <div class="flash error">@Model.Error</div> }
<div class="cards compact"><div class="stat"><div class="label">Failed events</div><div class="value">@Model.Failures.Count</div></div><div class="stat"><div class="label">Outbox records</div><div class="value">@Model.Outbox.Count</div></div><div class="stat"><div class="label">Background jobs</div><div class="value">@Model.Jobs.Count</div></div><div class="stat"><div class="label">Mode</div><div class="value small">@(Model.CanRetry ? "operator" : "read only")</div></div></div>
<div class="card toolbar-card"><form method="get" class="toolbar"><label>Event type<input name="EventType" value="@Model.EventType" placeholder="all event types" /></label><label>Outbox status<select name="OutboxStatus"><option value="">all unsent</option><option value="pending" selected="@(Model.OutboxStatus == "pending")">pending</option><option value="sending" selected="@(Model.OutboxStatus == "sending")">sending</option></select></label><button type="submit">Apply filters</button><a class="button secondary" href="/admin/recovery">Clear</a></form></div>
<div class="card table-card"><div class="card-heading"><div><h2>Event failures</h2><p class="muted">Newest unresolved records.</p></div></div><div class="table-wrap"><table><thead><tr><th>ID / stream</th><th>Stage</th><th>Error</th><th>Attempts</th><th>Action</th></tr></thead><tbody>@foreach (var row in Model.Failures) { <tr><td><code>#@row.Id</code><br /><span class="muted">@row.EventType · @row.StreamId v@row.StreamVersion</span></td><td>@row.Stage<br /><span class="muted">@row.HandlerName</span></td><td><pre>@row.Error</pre></td><td>@row.RetryCount<br /><span class="muted">@row.LastSeenAt.ToUniversalTime().ToString("MM-dd HH:mm 'UTC'")</span></td><td>@if (Model.CanRetry) { <form method="post" asp-page-handler="RetryEvent" class="inline" onsubmit="return confirm('Retry event failure #@row.Id?')"><input type="hidden" name="id" value="@row.Id" /><button class="danger" type="submit">Retry</button></form> } else { <span class="muted">read only</span> }</td></tr> } @if (Model.Failures.Count == 0) { <tr><td colspan="5" class="empty">No unresolved event failures.</td></tr> }</tbody></table></div></div>
<div class="card table-card"><div class="card-heading"><div><h2>Telegram outbox</h2><p class="muted">Reschedule makes the record eligible immediately; attempts and payload are preserved.</p></div></div><div class="table-wrap"><table><thead><tr><th>ID / chat</th><th>Status</th><th>Next attempt</th><th>Error</th><th>Preview</th><th>Action</th></tr></thead><tbody>@foreach (var row in Model.Outbox) { <tr><td><code>#@row.Id</code><br /><span class="muted">chat @row.ChatId</span></td><td><span class="pill">@row.Status</span><br /><span class="muted">@row.Attempts attempts</span></td><td>@row.NextAttemptAt.ToUniversalTime().ToString("MM-dd HH:mm:ss 'UTC'")</td><td><pre>@(row.LastError ?? "—")</pre></td><td><pre>@row.MessagePreview</pre></td><td>@if (Model.CanRetry) { <form method="post" asp-page-handler="RescheduleOutbox" class="inline" onsubmit="return confirm('Reschedule outbox record #@row.Id?')"><input type="hidden" name="id" value="@row.Id" /><button type="submit">Reschedule</button></form> } else { <span class="muted">read only</span> }</td></tr> } @if (Model.Outbox.Count == 0) { <tr><td colspan="6" class="empty">No matching unsent outbox records.</td></tr> }</tbody></table></div></div>
<div class="card table-card"><div class="card-heading"><div><h2>Background jobs</h2><p class="muted">Runtime status reported by the operations service.</p></div></div><div class="table-wrap"><table><thead><tr><th>Job</th><th>State</th><th>Heartbeat</th><th>Next run</th><th>Crashes</th><th>Last error</th></tr></thead><tbody>@foreach (var job in Model.Jobs) { <tr><td><code>@job.Name</code><br /><span class="muted">@job.Kind</span></td><td><span class="pill">@job.State</span></td><td>@(job.LastHeartbeatAt?.ToUniversalTime().ToString("MM-dd HH:mm:ss 'UTC'") ?? "—")</td><td>@(job.NextRunAt?.ToUniversalTime().ToString("MM-dd HH:mm:ss 'UTC'") ?? "—")</td><td>@job.CrashCount</td><td><pre>@(job.LastError ?? job.Note ?? "—")</pre></td></tr> } @if (Model.Jobs.Count == 0) { <tr><td colspan="6" class="empty">No jobs registered.</td></tr> }</tbody></table></div></div>
