@page "/admin/people"
@model PeopleModel
@{ ViewData["Title"] = "People"; }

<div class="page-heading"><div><div class="eyebrow">Identity + wallet service</div><h1>People</h1><p class="lede">One row per player. Group memberships below are the wallet scopes where the player has been observed; names come from known chats.</p></div><a class="button secondary" href="/admin/people">Refresh</a></div>
@if (Model.Error is not null) { <div class="flash error">@Model.Error</div> }
<div class="card toolbar-card"><form method="get" class="toolbar"><label>Search player or group<input name="Q" value="@Model.Q" placeholder="name, user ID, chat name" /></label><button type="submit">Search</button><a class="button secondary" href="/admin/people">Clear</a></form></div>
<div class="card table-card"><div class="card-heading"><div><h2>Players</h2><p class="muted">@Model.People.Count players shown · up to 500</p></div></div><div class="table-wrap"><table><thead><tr><th>Player</th><th>Wallets</th><th>Total coins</th><th>Groups / scopes</th><th>Last active</th></tr></thead><tbody>
@foreach (var person in Model.People) { <tr><td><strong>@person.DisplayName</strong><br /><code>@person.UserId</code></td><td>@person.WalletCount</td><td><b>@person.TotalCoins.ToString("N0")</b></td><td><div class="stacked">@foreach (var scope in person.Scopes) { <span class="scope"><span>@scope.Label</span><b>@scope.Coins.ToString("N0")</b><small>@scope.ScopeId</small></span> }</div></td><td class="muted">@person.LastActive.ToUniversalTime().ToString("yyyy-MM-dd HH:mm 'UTC'")</td></tr> }
@if (Model.People.Count == 0) { <tr><td colspan="5" class="empty">No players match the filter.</td></tr> }</tbody></table></div></div>
