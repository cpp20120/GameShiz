@page "/admin/ledger"
@model LedgerModel
@{ ViewData["Title"] = "Ledger"; }

<div class="page-heading">
    <div><div class="eyebrow">Wallet service</div><h1>Ledger</h1><p class="lede">Append-only money trail from the wallet database. Filters and rows are loaded remotely, so this screen also works with split databases.</p></div>
    <a class="button secondary" href="/admin/ledger">Refresh</a>
</div>
@if (TempData["flash"] is string flash) { <div class="flash">@flash</div> }
@if (TempData["error-message"] is string error) { <div class="flash error">@error</div> }
@if (Model.Error is not null) { <div class="flash error">@Model.Error</div> }

<div class="cards compact">
    <div class="stat"><div class="label">Rows / 24h</div><div class="value">@Model.Health.RowsWindow.ToString("N0")</div></div>
    <div class="stat"><div class="label">Credits / debits</div><div class="value">+@Model.Health.CreditsWindow.ToString("N0") / -@Model.Health.DebitsWindow.ToString("N0")</div></div>
    <div class="stat"><div class="label">Net / 24h</div><div class="value">@(Model.Health.NetWindow >= 0 ? "+" : "")@Model.Health.NetWindow.ToString("N0")</div></div>
    <div class="stat"><div class="label">Negative balances</div><div class="value">@Model.Health.NegativeBalanceRows.ToString("N0")</div></div>
    <div class="stat"><div class="label">Last append</div><div class="value small">@(Model.Health.LastLedgerAt == DateTimeOffset.MinValue ? "—" : Model.Health.LastLedgerAt.ToUniversalTime().ToString("MM-dd HH:mm 'UTC'"))</div></div>
</div>

<div class="card toolbar-card">
    <form method="get" class="toolbar">
        <label>User ID<input name="U" value="@Model.U" inputmode="numeric" placeholder="all users" /></label>
        <label>Scope / chat ID<input name="S" value="@Model.S" inputmode="numeric" placeholder="all scopes" /></label>
        <button type="submit">Apply filters</button>
        <a class="button secondary" href="/admin/ledger">Clear</a>
    </form>
</div>

<div class="card table-card">
    <div class="card-heading"><div><h2>Latest entries</h2><p class="muted">Showing @Model.Rows.Count rows, newest first. Revert appends a compensating row.</p></div><span class="pill">@(Model.CanRevert ? "SuperAdmin actions enabled" : "Read only")</span></div>
    <div class="table-wrap"><table>
        <thead><tr><th>ID</th><th>Time (UTC)</th><th>User</th><th>Scope</th><th>Delta</th><th>After</th><th>Reason</th><th>Action</th></tr></thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            var revertible = !row.Reason.StartsWith("ledger.revert#", StringComparison.Ordinal);
            <tr>
                <td><code>#@row.Id</code></td><td class="muted">@row.CreatedAt.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td><code>@row.UserId</code></td><td><code>@row.BalanceScopeId</code></td>
                <td class="@(row.Delta >= 0 ? "positive" : "negative")">@(row.Delta >= 0 ? "+" : "")@row.Delta</td>
                <td><b>@row.BalanceAfter</b></td><td><code>@row.Reason</code></td>
                <td>@if (Model.CanRevert && revertible) { <form method="post" asp-page-handler="Revert" class="inline" onsubmit="return confirm('Append a compensating entry for ledger line #@row.Id?')"><input type="hidden" name="ledgerId" value="@row.Id" /><input type="hidden" name="U" value="@Model.U" /><input type="hidden" name="S" value="@Model.S" /><button class="danger ghost" type="submit">Revert</button></form> } else { <span class="muted">—</span> }</td>
            </tr>
        }
        @if (Model.Rows.Count == 0) { <tr><td colspan="8" class="empty">No ledger entries match the filters.</td></tr> }
        </tbody>
    </table></div>
</div>
