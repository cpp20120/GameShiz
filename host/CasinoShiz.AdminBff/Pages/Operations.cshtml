@page "/admin/operations"
@model OperationsModel
@{ ViewData["Title"] = "Recovery"; }
<div class="page-heading"><div><div class="eyebrow">Operations service</div><h1>Failure recovery</h1><p class="lede">Retry persisted event failures and reschedule outbox delivery. The operation service remains authoritative for every mutation.</p></div><span class="pill @(Model.CanMutate ? "ok" : "warn")">@(Model.CanMutate ? "SuperAdmin" : "read only")</span></div>
@if (Model.Flash is not null) { <div class="@(Model.FlashError ? "flash error" : "flash")">@Model.Flash</div> }
@if (Model.Error is not null) { <div class="flash error">@Model.Error</div> }
<div class="card toolbar-card"><form method="get" class="toolbar"><label>Event type<input asp-for="EventType" placeholder="all event types" /></label><label>Outbox status<select asp-for="OutboxStatus"><option value="">pending + sending</option><option value="pending">pending</option><option value="sending">sending</option></select></label><button type="submit">Apply filters</button><a class="button secondary" href="/admin/operations">Clear</a></form></div>
@if (!Model.CanMutate) { <div class="flash error">Read-only access. Retry actions require SuperAdmin.</div> }
<div class="card table-card"><div class="card-heading"><div><h2>Event failures</h2><p class="muted">Persisted failures available for redispatch.</p></div><span class="pill warn">@Model.Failures.Count</span></div><div class="table-wrap"><table><thead><tr><th>ID</th><th>Type / stage</th><th>Error</th><th>Action</th></tr></thead><tbody>
@foreach (var x in Model.Failures) {
    <tr><td><code>#@x.Id</code></td><td>@x.EventType<br /><span class="muted">@x.Stage</span></td><td><pre>@x.Error</pre></td><td>@if (Model.CanMutate) { <form method="post" asp-page-handler="RetryEvent" class="inline" onsubmit="return confirm('Redispatch persisted event #@x.Id?')"><input type="hidden" name="id" value="@x.Id" /><input type="hidden" asp-for="EventType" /><input type="hidden" asp-for="OutboxStatus" /><button class="danger" type="submit">Retry</button></form> } else { <span class="muted">Read only</span> }</td></tr>
}
@if (Model.Failures.Count == 0) { <tr><td colspan="4" class="empty">No event failures match the filters.</td></tr> }
</tbody></table></div></div>

<div class="card table-card"><div class="card-heading"><div><h2>Telegram outbox</h2><p class="muted">Pending and sending records waiting for delivery.</p></div><span class="pill">@Model.Outbox.Count</span></div><div class="table-wrap"><table><thead><tr><th>ID</th><th>Chat / status</th><th>Attempts</th><th>Scheduled / lease</th><th>Message</th><th>Error</th><th>Action</th></tr></thead><tbody>
@foreach (var x in Model.Outbox) {
    <tr><td><code>#@x.Id</code></td><td>@x.ChatId<br /><span class="pill">@x.Status</span></td><td>@x.Attempts</td><td class="muted">@x.NextAttemptAt<br />@x.LockedUntil</td><td><pre>@x.MessagePreview</pre></td><td><pre>@(x.LastError ?? "—")</pre></td><td>@if (Model.CanMutate) { <form method="post" asp-page-handler="RescheduleOutbox" class="inline" onsubmit="return confirm('Reschedule outbox #@x.Id now?')"><input type="hidden" name="id" value="@x.Id" /><input type="hidden" asp-for="EventType" /><input type="hidden" asp-for="OutboxStatus" /><button type="submit">Reschedule</button></form> } else { <span class="muted">Read only</span> }</td></tr>
}
@if (Model.Outbox.Count == 0) { <tr><td colspan="7" class="empty">No outbox records match the filters.</td></tr> }
</tbody></table></div></div>

<div class="card table-card"><div class="card-heading"><div><h2>Background jobs</h2><p class="muted">Runtime state reported by the operations service.</p></div><span class="pill">@Model.Jobs.Count</span></div><div class="table-wrap"><table><thead><tr><th>Name</th><th>State</th><th>Last completed</th><th>Error</th></tr></thead><tbody>
@foreach (var x in Model.Jobs) { <tr><td><code>@x.Name</code></td><td><span class="pill">@x.State</span></td><td class="muted">@x.LastCompletedAt</td><td><pre>@(x.LastError ?? "—")</pre></td></tr> }
@if (Model.Jobs.Count == 0) { <tr><td colspan="4" class="empty">No jobs reported.</td></tr> }
</tbody></table></div></div>
