@page "/admin"
@model IndexModel
@{ ViewData["Title"] = "Dashboard"; }
<div class="page-heading"><div><div class="eyebrow">Operations console</div><h1>Dashboard</h1><p class="lede">Live snapshot across wallet and operations services. Updated on request; long-term charts live in Grafana.</p></div><a class="button secondary" href="/admin">Refresh</a></div>
@if (Model.Error is not null) { <div class="flash error">Some services did not answer: @Model.Error</div> }
<div class="section-title"><h2>Economy now</h2><span class="pill ok">live</span></div>
<div class="cards"><div class="stat"><div class="label">Coin supply</div><div class="value">@Model.Totals.CoinSupply.ToString("N0")</div></div><div class="stat"><div class="label">Wallets</div><div class="value">@Model.Totals.Wallets.ToString("N0")</div></div><div class="stat"><div class="label">Players</div><div class="value">@Model.Engagement.Users.ToString("N0")</div></div><div class="stat"><div class="label">Active users / 24h</div><div class="value">@Model.Engagement.TransactingUsers24H.ToString("N0")</div></div><div class="stat"><div class="label">New wallets / 24h</div><div class="value">@Model.Engagement.NewWallets24H.ToString("N0")</div></div><div class="stat"><div class="label">Daily claimers</div><div class="value">@Model.Engagement.DailyClaimersToday.ToString("N0")</div></div></div>
<div class="cards compact"><div class="stat"><div class="label">P50 / P90 / P99</div><div class="value small">@Model.Totals.P50Coins.ToString("N0") / @Model.Totals.P90Coins.ToString("N0") / @Model.Totals.P99Coins.ToString("N0")</div></div><div class="stat"><div class="label">Top 1% / 5% / 10%</div><div class="value small">@Model.Totals.Top1Coins.ToString("N0") / @Model.Totals.Top5Coins.ToString("N0") / @Model.Totals.Top10Coins.ToString("N0")</div></div><div class="stat"><div class="label">Transfers / 24h</div><div class="value">@Model.Social.Transfers.ToString("N0")</div></div><div class="stat"><div class="label">Transfer volume</div><div class="value">@Model.Social.TransferCoins.ToString("N0")</div></div><div class="stat"><div class="label">Ledger rows / 24h</div><div class="value">@Model.Ledger.RowsWindow.ToString("N0")</div></div><div class="stat"><div class="label">Ledger net / 24h</div><div class="value">@(Model.Ledger.NetWindow >= 0 ? "+" : "")@Model.Ledger.NetWindow.ToString("N0")</div></div></div>
<div class="split-grid"><div class="card"><div class="card-heading"><div><h2>Integrity</h2><p class="muted">Wallet balance vs latest ledger checkpoint.</p></div><span class="pill @(Model.Integrity.MismatchedWallets == 0 ? "ok" : "warn")">@(Model.Integrity.MismatchedWallets == 0 ? "consistent" : "attention")</span></div><div class="key-values"><span>Wallet / ledger supply <b>@Model.Integrity.WalletCoinSupply.ToString("N0") / @Model.Integrity.LatestLedgerSupply.ToString("N0")</b></span><span>Mismatched wallets <b>@Model.Integrity.MismatchedWallets.ToString("N0")</b></span><span>Without ledger <b>@Model.Integrity.WalletsWithoutLedger.ToString("N0")</b></span><span>Gini / top decile <b>@Model.Integrity.BalanceGini.ToString("0.000") / @Model.Integrity.TopDecileCoinSharePercent.ToString("0.0")%</b></span></div></div><div class="card"><div class="card-heading"><div><h2>Game activity / 24h</h2><p class="muted">Stake and payout detected in wallet ledger.</p></div><a href="/admin/meta-economy">details →</a></div><div class="key-values"><span>Active players <b>@Model.Period.ActiveUsers.ToString("N0")</b></span><span>Stake <b>@Model.Period.Stake.ToString("N0")</b></span><span>Payout <b>@Model.Period.Payout.ToString("N0")</b></span></div><table><thead><tr><th>Game</th><th>Users</th><th>Stake</th></tr></thead><tbody>@foreach (var game in Model.Period.TopGames) { <tr><td><code>@game.Module</code></td><td>@game.Users</td><td>@game.Stake.ToString("N0")</td></tr> } @if (Model.Period.TopGames.Count == 0) { <tr><td colspan="3" class="empty">No game ledger activity.</td></tr> }</tbody></table></div></div>
<div class="split-grid"><div class="card table-card"><div class="card-heading"><div><h2>Operations attention</h2><p class="muted">Latest failures and outbox records.</p></div><a href="/admin/recovery">open recovery →</a></div><table><thead><tr><th>Type</th><th>Record</th><th>State</th></tr></thead><tbody>@foreach (var failure in Model.Failures) { <tr><td>failure</td><td><code>#@failure.Id @failure.EventType</code></td><td><span class="pill warn">@failure.RetryCount retries</span></td></tr> } @foreach (var row in Model.Outbox) { <tr><td>outbox</td><td><code>#@row.Id chat @row.ChatId</code></td><td><span class="pill">@row.Status</span></td></tr> } @if (Model.Failures.Count == 0 && Model.Outbox.Count == 0) { <tr><td colspan="3" class="empty">No pending attention items.</td></tr> }</tbody></table></div><div class="card table-card"><div class="card-heading"><div><h2>Jobs</h2><p class="muted">Background runtime state.</p></div></div><table><thead><tr><th>Name</th><th>State</th><th>Heartbeat</th></tr></thead><tbody>@foreach (var job in Model.Jobs) { <tr><td><code>@job.Name</code></td><td><span class="pill">@job.State</span></td><td class="muted">@(job.LastHeartbeatAt?.ToUniversalTime().ToString("MM-dd HH:mm 'UTC'") ?? "—")</td></tr> } @if (Model.Jobs.Count == 0) { <tr><td colspan="3" class="empty">No jobs reported.</td></tr> }</tbody></table></div></div>
