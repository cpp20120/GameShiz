@page "/admin"
@model CasinoShiz.Host.Pages.Admin.IndexModel
@{ ViewData["Title"] = "Dashboard"; }

<h2>Dashboard</h2>

<div class="cards">
    <div class="stat"><div class="label">People (distinct)</div><div class="value">@Model.PeopleCount</div></div>
    <div class="stat"><div class="label">Wallet rows</div><div class="value">@Model.WalletRowCount</div></div>
    <div class="stat"><div class="label">Total coins (sum)</div><div class="value">@Model.TotalCoins</div></div>
    <div class="stat"><div class="label">Pending bets</div><div class="value">@Model.PendingBets</div></div>
    <div class="stat"><div class="label">Domain events</div><div class="value">@Model.EventCount</div></div>
</div>

<div class="card">
    <h3>Background / host jobs</h3>
    <p class="muted">Module jobs supervised by <code>BackgroundJobRunner</code> plus host-level periodic services. Use <code>/__debug_jobs</code> for the Telegram debug view.</p>
    @if (Model.BackgroundJobs.Count == 0)
    {
        <p class="muted">No jobs registered.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Kind</th>
                    <th>State</th>
                    <th>Heartbeat</th>
                    <th>Next</th>
                    <th>Completed</th>
                    <th>Failed</th>
                    <th>Crashes</th>
                    <th>Backoff</th>
                    <th>Note / Error</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in Model.BackgroundJobs)
                {
                    <tr>
                        <td><code>@job.Name</code></td>
                        <td><span class="pill">@job.Kind</span></td>
                        <td><span class="pill">@job.State</span></td>
                        <td class="muted">@(job.LastHeartbeatAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</td>
                        <td class="muted">@(job.NextRunAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</td>
                        <td class="muted">@(job.LastCompletedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</td>
                        <td class="muted">@(job.LastFailedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</td>
                        <td>@job.CrashCount</td>
                        <td>@(job.RestartBackoffMs?.ToString() ?? "—")</td>
                        <td class="muted">@(job.LastError ?? job.Note ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="card">
    <h3>Sticker game plays</h3>
    <p class="muted">Counts resolved Telegram sticker games from domain events. <code>dice</code> is the 🎰 slots game.</p>
    <table>
        <thead>
            <tr>
                <th>Game</th>
                <th>Total plays</th>
                <th>Today</th>
                <th>Last played</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var x in Model.StickerGames)
            {
                <tr>
                    <td><code>@x.GameId</code> @x.Label</td>
                    <td>@x.Plays</td>
                    <td>@x.PlaysToday</td>
                    <td>@(x.LastPlayedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card">
    <h3>Modules loaded</h3>
    <table>
        <thead><tr><th>Id</th><th>Name</th><th>Version</th></tr></thead>
        <tbody>
            @foreach (var m in Model.Modules.OrderBy(m => m.Id))
            {
                <tr>
                    <td><code>@m.Id</code></td>
                    <td>@m.DisplayName</td>
                    <td>@m.Version</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card">
    <h3>Events by module</h3>
    @if (Model.EventsByModule.Count == 0)
    {
        <p class="muted">No domain events recorded yet.</p>
    }
    else
    {
        <table>
            <thead><tr><th>Module</th><th>Events</th></tr></thead>
            <tbody>
                @foreach (var x in Model.EventsByModule)
                {
                    <tr><td><code>@x.Module</code></td><td>@x.Count</td></tr>
                }
            </tbody>
        </table>
    }
</div>