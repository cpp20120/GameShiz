@page "/admin/events"
@model CasinoShiz.Host.Pages.Admin.EventsModel
@{ ViewData["Title"] = "Events"; }

<h2>Events</h2>

<div class="card">
    <form method="get" class="inline">
        <label>Module/game:</label>
        <select name="Module" onchange="this.form.submit()">
            <option value="">(all)</option>
            @foreach (var m in Model.Modules)
            {
                if ((Model.Module ?? "") == m) { <option value="@m" selected>@m</option> }
                else { <option value="@m">@m</option> }
            }
        </select>
        <label>Chat:</label>
        <select name="ChatId" onchange="this.form.submit()">
            <option value="">(all)</option>
            @foreach (var c in Model.Chats)
            {
                if (Model.ChatId == c.ChatId) { <option value="@c.ChatId" selected>@c.Label</option> }
                else { <option value="@c.ChatId">@c.Label</option> }
            }
        </select>
        <a href="/admin/groups" class="muted" style="margin-left:6px" title="Where chat list comes from">chats &amp; groups</a>
        <noscript><button type="submit">Filter</button></noscript>
    </form>
    <p class="muted" style="margin:8px 0 0 0">
        Global timeline over <code>event_log</code>, <code>module_events</code> and <code>meta_event_log</code>.
        Source <code>domain</code> = domain event log, <code>es</code> = module event streams, <code>meta</code> = meta history.
    </p>
</div>

<div class="card">
    <h3>Sub-events by type</h3>
    @if (Model.EventTypeCounts.Count == 0)
    {
        <p class="muted">No event types for this filter.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Source</th>
                    <th>Type</th>
                    <th>Count</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var x in Model.EventTypeCounts)
                {
                    <tr>
                        <td><span class="pill">@x.Source</span></td>
                        <td><code>@x.EventType</code></td>
                        <td>@x.Count</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="card">
    <h3>Timeline</h3>
    <table>
        <thead>
            <tr>
                <th style="width: 60px">#</th>
                <th>Source</th>
                <th>When</th>
                <th>Type</th>
                <th>Stream</th>
                <th style="width: 50%">Payload</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Rows)
            {
                <tr>
                    <td class="muted">@e.Id</td>
                    <td><span class="pill">@e.Source</span></td>
                    <td class="muted">@e.OccurredAt.UtcDateTime.ToString("MM-dd HH:mm:ss")</td>
                    <td><code>@e.EventType</code></td>
                    <td class="muted">
                        @if (!string.IsNullOrEmpty(e.StreamId))
                        {
                            <code>@e.StreamId</code>
                            @if (e.Version.HasValue)
                            {
                                <span> v@e.Version.Value</span>
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                    <td><pre>@e.PayloadJson</pre></td>
                </tr>
            }
            @if (Model.Rows.Count == 0)
            {
                <tr><td colspan="6" class="muted">No events for this filter.</td></tr>
            }
        </tbody>
    </table>
</div>
<p class="muted">Showing up to 300 most recent events.</p>